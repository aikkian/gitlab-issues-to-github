# GitLab Configuration
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=12345

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repo

# Optional: JSON mapping of GitLab usernames to GitHub usernames
# USERNAME_MAP={"gitlab_user1": "github_user1", "gitlab_user2": "github_user2"}

# Optional: Override colors for scoped label prefixes (e.g. "x-priority :: P1")
# SCOPE_COLORS={"x-priority": "d93f0b", "x-type": "0075ca", "x-team": "0e8a16", "x-workflow": "5319e7", "status": "fbca04"}

# Optional: Set to 0 to skip image migration (images will use absolute GitLab URLs instead)
# MIGRATE_IMAGES=1

# Optional: Set to 1 to preview migration without creating anything
# DRY_RUN=1
